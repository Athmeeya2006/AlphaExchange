# Copy this file to .env and fill in values
# NEVER commit .env to git — it contains credentials
#
# This file shows every environment variable used by the trade-eval-platform
# docker-compose stack. Replace placeholder values with your own.

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=<your-kafka-brokers>                      # Comma-separated broker addresses
BUILD_JOBS_TOPIC=<build-jobs-topic>                     # Topic for build job messages
ORCHESTRATOR_EVENTS_TOPIC=<orchestrator-events-topic>   # Topic for orchestrator lifecycle events
BOT_TELEMETRY_TOPIC=<bot-telemetry-topic>               # Topic for bot-fleet telemetry data
LEADERBOARD_UPDATES_TOPIC=<leaderboard-updates-topic>   # Topic for leaderboard score updates
SUBMISSIONS_TOPIC=<submissions-topic>                   # Topic for new submission notifications

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=<redis-host>:<redis-port>                     # Redis connection address for caching and pub/sub

# ── MinIO (S3-compatible object storage) ──────────────────────────────────
MINIO_ENDPOINT=<minio-host>:<minio-port>                # MinIO server endpoint
MINIO_ACCESS_KEY=<your-minio-access-key>                # MinIO access key (like AWS_ACCESS_KEY_ID)
MINIO_SECRET_KEY=<your-minio-secret-key>                # MinIO secret key (like AWS_SECRET_ACCESS_KEY)
MINIO_BUCKET=<your-bucket-name>                         # Bucket for contestant submission archives
MINIO_USE_SSL=<true|false>                              # Whether to use TLS for MinIO connections

# ── TimescaleDB (telemetry + time-series data) ─────────────────────────────
TIMESCALE_DSN=<postgres-dsn-for-timescaledb>            # DSN for TimescaleDB storing telemetry metrics

# ── Postgres (orchestrator state DB, separate instance) ───────────────────
ORCHESTRATOR_DB_DSN=<postgres-dsn-for-orchestrator>     # DSN for Postgres storing orchestrator state

# ── Submission API ─────────────────────────────────────────────────────────
SUBMISSION_API_PORT=<port>                              # HTTP port the submission API listens on
MAX_UPLOAD_SIZE_MB=<max-mb>                             # Maximum upload size in megabytes per submission

# ── Build Worker ───────────────────────────────────────────────────────────
MAX_CONCURRENT_BUILDS=<count>                           # Max parallel container builds per worker
BUILD_TIMEOUT_SECONDS=<seconds>                         # Timeout before a build is killed
WORK_DIR=<path>                                         # Local directory for temporary build artifacts

# ── Orchestrator ───────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL_SECONDS=<seconds>                    # How often the orchestrator emits heartbeats
ORPHAN_DETECTION_SECONDS=<seconds>                      # Time before a stale test run is considered orphaned
AUTO_TRIGGER_TESTS=<true|false>                         # Whether to auto-start tests on submission

# ── Bot Fleet ──────────────────────────────────────────────────────────────
MAX_BOTS_PER_POD=<count>                                # Maximum simulated bots per pod instance
BOT_REQUEST_TIMEOUT_MS=<ms>                             # Timeout for each bot HTTP request to the exchange
TEST_DEFAULT_DURATION_SECONDS=<seconds>                 # Default test run duration
TEST_DEFAULT_BOT_COUNT=<count>                          # Default number of bots spawned per test

# ── Telemetry Ingester ─────────────────────────────────────────────────────
WINDOW_SIZE_SECONDS=<seconds>                           # Tumbling window size for metric aggregation
TELEMETRY_BATCH_SIZE=<count>                            # Number of events to batch before flushing to DB
FLUSH_INTERVAL_MS=<ms>                                  # Max time between flushes even if batch is not full
REORDER_BUFFER_MS=<ms>                                  # Buffer duration to handle out-of-order events

# ── Leaderboard API ────────────────────────────────────────────────────────
LEADERBOARD_API_PORT=<port>                             # HTTP/WebSocket port the leaderboard API listens on
LEADERBOARD_UPDATE_INTERVAL_MS=<ms>                     # How often to push leaderboard updates to clients
MAX_WEBSOCKET_CONNECTIONS=<count>                        # Maximum concurrent WebSocket connections

# ── Sandbox (contestant container constraints) ─────────────────────────────
SANDBOX_MEMORY_LIMIT=<limit>                            # Docker memory limit for contestant containers (e.g. 512m)
SANDBOX_CPU_CORES=<cores>                               # CPU cores pinned to contestant containers (e.g. 2,3)
CONTESTANT_NETWORK=<network-name>                       # Isolated Docker network for contestant containers

# ── Security ───────────────────────────────────────────────────────────────
ADMIN_API_KEY=<your-admin-api-key>                      # API key for admin endpoints — change in production

# ── General ────────────────────────────────────────────────────────────────
ENVIRONMENT=<development|staging|production>             # Runtime environment, controls logging format
LOG_LEVEL=<debug|info|warn|error>                       # Minimum log level
INTERNAL_API_TOKEN=internal-dev-token
